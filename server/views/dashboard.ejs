<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Clothify Admin Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; background: #0F172A; color: #E2E8F0; padding: 40px 20px; }
    .container { max-width: 1000px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
    .brand { font-size: 28px; font-weight: 800; background: linear-gradient(135deg, #A78BFA, #EC4899); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 40px; }
    .stat-card { background: #1E293B; border: 1px solid #334155; border-radius: 12px; padding: 24px; }
    .stat-card h3 { font-size: 13px; color: #64748B; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
    .stat-card p { font-size: 32px; font-weight: 700; }
    .stat-card span { font-size: 13px; color: #A78BFA; }
    .section-title { font-size: 18px; font-weight: 600; margin-bottom: 16px; }
    .orders-table { width: 100%; border-collapse: collapse; background: #1E293B; border-radius: 12px; overflow: hidden; border: 1px solid #334155; }
    .orders-table th { padding: 14px 16px; text-align: left; font-size: 11px; text-transform: uppercase; letter-spacing: 1px; color: #64748B; background: #0F172A; border-bottom: 1px solid #334155; }
    .orders-table td { padding: 14px 16px; font-size: 14px; border-bottom: 1px solid #1E293B; color: #CBD5E1; }
    .orders-table tr:last-child td { border-bottom: none; }
    .orders-table tr:hover td { background: #273444; }
    .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; }
    .badge-order { background: #2D1B69; color: #A78BFA; }
    .badge-packing { background: #422006; color: #FBBF24; }
    .badge-shipped { background: #1E3A5F; color: #60A5FA; }
    .badge-delivered { background: #064E3B; color: #34D399; }
    .invoice-link { color: #A78BFA; text-decoration: none; font-size: 13px; }
    .invoice-link:hover { text-decoration: underline; }
    .footer { margin-top: 40px; text-align: center; color: #334155; font-size: 13px; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div>
        <div class="brand">Clothify Admin</div>
        <p style="color:#64748B;font-size:14px;">Server-side rendered · <%= new Date().toLocaleDateString('en-IN', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
      </div>
      <p style="color:#64748B;font-size:13px;">Logged in as Admin</p>
    </div>

    <div class="stats">
      <div class="stat-card">
        <h3>Total Orders</h3>
        <p><%= stats.totalOrders %></p>
        <span>All time</span>
      </div>
      <div class="stat-card">
        <h3>Total Revenue</h3>
        <p>₹<%= stats.totalRevenue.toLocaleString('en-IN') %></p>
        <span>From paid orders</span>
      </div>
      <div class="stat-card">
        <h3>Pending Orders</h3>
        <p><%= stats.pendingOrders %></p>
        <span>Needs attention</span>
      </div>
    </div>

    <h2 class="section-title">Recent Orders</h2>

    <table class="orders-table">
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Customer</th>
          <th>Amount</th>
          <th>Payment</th>
          <th>Status</th>
          <th>Date</th>
          <th>Invoice</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(function(order) { %>
          <tr>
            <td style="font-family:monospace;font-size:12px;">#<%= order._id.toString().slice(-8).toUpperCase() %></td>
            <td><%= order.address?.name || 'N/A' %></td>
            <td>₹<%= order.amount %></td>
            <td><%= order.paymentMethod %></td>
            <td>
              <span class="badge badge-<%= (order.status || 'order').toLowerCase().split(' ')[0] %>">
                <%= order.status || 'Order Placed' %>
              </span>
            </td>
            <td><%= new Date(order.date).toLocaleDateString('en-IN') %></td>
            <td><a href="/admin/invoice/<%= order._id %>" class="invoice-link">View Invoice →</a></td>
          </tr>
        <% }); %>
      </tbody>
    </table>

    <div class="footer">
      <p>Clothify Admin Panel · Built with Express + EJS (SSR)</p>
    </div>
  </div>
</body>
</html>